# Copy this file to .env and fill in your values.
# .env is loaded automatically by pytest for all test tiers.

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for live LLM adapter tests.
OPENAI_API_KEY=your-openai-api-key-here

# ── Live test opt-in ──────────────────────────────────────────────────────────
# Uncomment to enable live tests.
# LIVE_TESTS=1
